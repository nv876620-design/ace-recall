{
  "name": "@alistar.max/coderecall-lang-swift",
  "version": "0.1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodingOX/CodeRecall.git"
  },
  "homepage": "https://github.com/CodingOX/CodeRecall#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "tree-sitter": "^0.22.4",
    "tree-sitter-swift": "^0.7.1"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ]
}
